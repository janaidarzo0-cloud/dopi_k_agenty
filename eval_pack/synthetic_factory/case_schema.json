{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Synthetic research case blueprint",
  "type": "object",
  "required": ["case_id", "kind", "seed", "n", "user_prompt"],
  "properties": {
    "case_id": {"type": "string", "pattern": "^[a-zA-Z0-9_\\-]+$"},
    "kind": {
      "type": "string",
      "enum": ["descriptive_no_kpi", "kpi_confounder", "multiselect_block", "weak_signal_caution", "brand_lift_frequency", "misleading_questionnaire"]
    },
    "seed": {"type": "integer"},
    "n": {"type": "integer", "minimum": 20},
    "user_prompt": {"type": "string"},
    "max_iterations": {"type": "integer", "minimum": 2, "maximum": 96},
    "question_timeout_seconds": {"type": "integer", "minimum": 0, "maximum": 600},
    "requires_caution": {"type": "boolean"},
    "questionnaire_note": {"type": "string"}
  },
  "additionalProperties": true
}
